// tests/modules/local/ranking.nf.test
nextflow_process {

    name "Test Process RANKING"
    script "modules/local/ranking.nf"
    process "RANKING"

    options "-stub-run"

    test("RANKING emits final ranked outputs") {

        when {
            params {
                outdir = "tests/results"
                ranking_network = "neighbours"
                ranking_features = "degree,betweenness,closeness,eigen_centrality,page_rank,highest_score"
            }
            process {
                """
                input[0] = file("${projectDir}/tests/fixtures/hhnet_subnet_metrics.tsv")
                input[1] = file("${projectDir}/tests/fixtures/hhnet_neighbour_metrics.tsv")
                input[2] = file("${projectDir}/tests/fixtures/druggability.tsv")
                input[3] = file("${projectDir}/tests/fixtures/ml_scores.tsv")
                input[4] = file("${projectDir}/tests/fixtures/citations.tsv")
                """
            }
        }

        then {
            assert process.success
            assert process.trace.tasks().size() == 1

            assert process.out[0].size() == 1
            assert path(process.out[0].get(0)).getFileName().toString() == "final_ranked.tsv"
            assert path(process.out[0].get(0)).readLines().size() >= 2

            assert process.out[1].size() == 1
            assert path(process.out[1].get(0)).getFileName().toString() == "final_ranked.rds"
        }
    }
}