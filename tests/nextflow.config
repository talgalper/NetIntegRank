/*
========================================================================================
    Nextflow config file for running tests
========================================================================================
*/

profiles {
  test_full {
    params {
      outdir = "${projectDir}/tests/results/full_stub_manual"
      de_results = "${projectDir}/tests/fixtures/DE_test.csv"
      ppi_network = "${projectDir}/tests/fixtures/PPI_test.csv"
      druggability = "${projectDir}/assets/druggability_scores_annot2.0.csv"
      ml_scores = "${projectDir}/assets/ML_data.csv"
      citations = "${projectDir}/assets/PubTator3_counts.csv"

      hhnet_network_name = "string_phys"
      hhnet_score_name = "logfc_abs"
      hhnet_num_permutations = 10
      hhnet_compile_fortran = "never"
      hhnet_num_cores = 2
      hhnet_run_id = "test"
      hhnet_min_cluster_size = 2
      hhnet_n_clusters = 0
      hhnet_seed = 1234
      hhnet_node_id_type = "ensembl_gene_id"
      hhnet_extra_colours = ""
      hhnet_plot_max_nodes = 5000

      ranking_network = "neighbours"
      ranking_features = "degree,betweenness,closeness,eigen_centrality,page_rank,highest_score"
      negative_features = ""
      ranking_step = 0.1
      write_rds = true
    }
  }
}