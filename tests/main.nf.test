nextflow_pipeline {

    name "Test NetIntegRank full pipeline"
    script "main.nf"

    test("Pipeline smoke test with stub run") {
        options "-stub-run"

        when {
            params {
                outdir = "${projectDir}/tests/results/full_stub"
                scores = "${projectDir}/tests/fixtures/DE_test.csv"
                ppi_network = "${projectDir}/tests/fixtures/PPI_test.csv"
                druggability = "${projectDir}/assets/druggability_scores_annot2.0.csv"
                ml_scores = "${projectDir}/assets/ML_data.csv"
                citations = "${projectDir}/assets/PubTator3_counts.csv"
                gene_map = null

                hhnet_network_name = "string_phys"
                hhnet_score_name = "logfc_abs"
                hhnet_num_permutations = 10
                hhnet_compile_fortran = "never"
                hhnet_num_cores = 2
                hhnet_run_id = "test"

                hhnet_min_cluster_size = 2
                hhnet_n_clusters = 0
                hhnet_seed = 1234
                hhnet_node_id_type = "ensembl_gene_id"
                hhnet_extra_colours = ""
                hhnet_plot_max_nodes = 5000

                ranking_network = "neighbours"
                ranking_features = "degree,betweenness,closeness,eigen_centrality,page_rank,drug_score"
                negative_features = ""
                ranking_step = 0.1
                write_rds = true
            }
        }

        then {
            assert workflow.success
            assert workflow.exitStatus == 0
            assert workflow.trace.failed().size() == 0

            // keep this loose unless your task count is guaranteed stable
            assert workflow.trace.tasks().size() >= 3
        }
    }

    test("Pipeline end-to-end run produces core outputs") {

        when {
            params {
                outdir = "${projectDir}/tests/results/full_real"
                scores = "${projectDir}/tests/fixtures/DE_test.csv"
                ppi_network = "${projectDir}/tests/fixtures/PPI_test.csv"
                druggability = "${projectDir}/assets/druggability_scores_annot2.0.csv"
                ml_scores = "${projectDir}/assets/ML_data.csv"
                citations = "${projectDir}/assets/PubTator3_counts.csv"
                gene_map = null

                hhnet_network_name = "string_phys"
                hhnet_score_name = "logfc_abs"
                hhnet_num_permutations = 10
                hhnet_compile_fortran = "never"
                hhnet_num_cores = 2
                hhnet_run_id = "test"

                hhnet_min_cluster_size = 2
                hhnet_n_clusters = 0
                hhnet_seed = 1234
                hhnet_node_id_type = "ensembl_gene_id"
                hhnet_extra_colours = ""
                hhnet_plot_max_nodes = 5000

                ranking_network = "neighbours"
                ranking_features = "degree,betweenness,closeness,eigen_centrality,page_rank,drug_score"
                negative_features = ""
                ranking_step = 0.1
                write_rds = true
            }
        }
        
        then {
            assert workflow.success
            assert workflow.exitStatus == 0
            assert workflow.trace.failed().size() == 0
        
            assert path("${params.outdir}/hhnet/clusters_string_phys_logfc_abs.tsv").exists()
            assert path("${params.outdir}/hhnet_processing/hhnet_subnet_metrics.tsv").exists()
            assert path("${params.outdir}/hhnet_processing/hhnet_neighbour_metrics.tsv").exists()
            assert path("${params.outdir}/ranking/final_ranked.tsv").exists()
            assert path("${params.outdir}/ranking/final_ranked_missing_annotations.tsv").exists()
        
            assert path("${params.outdir}/ranking/final_ranked.tsv").readLines().size() >= 2
        
            assert snapshot(
                path("${params.outdir}/hhnet/clusters_string_phys_logfc_abs.tsv"),
                path("${params.outdir}/hhnet_processing/hhnet_subnet_metrics.tsv"),
                path("${params.outdir}/hhnet_processing/hhnet_neighbour_metrics.tsv"),
                path("${params.outdir}/ranking/final_ranked.tsv")
            ).match("core_outputs")
        }
    }
}